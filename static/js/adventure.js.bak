      },
      {
        id: 15, game: "code_output", label: "Wielki Finał!", coins: 30, icon: "🏆",
        code: 'def f(n):\n    if n <= 1:\n        return n\n    return f(n-1) + f(n-2)\n\nprint(f(6))',
