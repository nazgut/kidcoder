/* ============ LOCAL GAME STATE ============ */
let advGameAttempts = 0;
let advTFIndex = 0;
let advTFWrong = 0;
let advSortPlaced = [];
let advSortShuffled = [];

/* ============ HELPERS ============ */
function adventureProgress() {
  if (!state.progress.adventure_completed) state.progress.adventure_completed = [];
  return state.progress.adventure_completed;
}

function adventureCoinsTotal() {
  const completed = adventureProgress();
  let coins = 0;
  ADVENTURE_WORLDS.forEach(w => {
    w.stops.forEach(s => {
      if (completed.includes(s.id)) coins += s.coins;
    });
  });
  return coins;
}

function advShuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

/* ============ WORLD SELECTION (TAB VIEW) ============ */
function renderAdventureMap() {
  if (!dom.adventureGrid) return;
  dom.adventureGrid.innerHTML = "";
  const completed = adventureProgress();

  ADVENTURE_WORLDS.forEach(world => {
    const worldDiv = document.createElement("div");
    worldDiv.className = `adventure-world-card world-${world.id}`;

    const doneCount = world.stops.filter(s => completed.includes(s.id)).length;
    const total = world.stops.length;
    const pct = total > 0 ? Math.round((doneCount / total) * 100) : 0;
    const worldCoins = world.stops.filter(s => completed.includes(s.id)).reduce((sum, s) => sum + s.coins, 0);

    worldDiv.innerHTML = `
      <div class="adventure-world-card-banner">
        <span class="adventure-world-icon">${world.icon}</span>
      </div>
      <div class="adventure-world-card-body">
        <div class="adventure-world-name">${esc(world.name)}</div>
        <div class="adventure-world-subtitle">${esc(world.subtitle)}</div>
        <div class="adventure-world-progress">
          <div class="adventure-progress-bar">
            <div class="adventure-progress-fill" style="width:${pct}%"></div>
          </div>
          <span>${doneCount}/${total}</span>
        </div>
        ${worldCoins > 0 ? `<div class="adventure-world-coins">🪙 ${worldCoins} monet</div>` : ""}
      </div>
    `;
    worldDiv.addEventListener("click", () => enterAdventureWorld(world.id));
    dom.adventureGrid.appendChild(worldDiv);
  });

  if (dom.adventureCoinsTotal) dom.adventureCoinsTotal.textContent = adventureCoinsTotal();
}

/* ============ ENTER WORLD → PATH VIEW ============ */
function enterAdventureWorld(worldId) {
  const world = ADVENTURE_WORLDS.find(w => w.id === worldId);
  if (!world) return;
  state.adventureWorld = world;
  state.adventureActive = true;

  dom.adventureTitle.textContent = world.icon + " " + world.name;
  if (dom.adventureCoins) dom.adventureCoins.textContent = "🪙 " + adventureCoinsTotal();
  if (dom.adventureBannerBg) {
    dom.adventureBannerBg.className = "adventure-world-banner-bg";
    if (world.id === 2) dom.adventureBannerBg.classList.add("world-2");
    if (world.id === 3) dom.adventureBannerBg.classList.add("world-3");
  }
  if (dom.adventureBannerIcon) dom.adventureBannerIcon.textContent = world.icon;
  if (dom.adventureBannerTitle) dom.adventureBannerTitle.textContent = world.name;

  // Ensure path visible, game hidden
  if (dom.adventurePathContainer) dom.adventurePathContainer.style.display = "";
  if (dom.adventureGameArea) dom.adventureGameArea.style.display = "none";

  renderAdventurePath();
  showScreen("adventure");
}

/* ============ RENDER PATH WITH STOPS ============ */
function renderAdventurePath() {
  const pathEl = dom.adventurePath;
  if (!pathEl) return;
  const world = state.adventureWorld;
  if (!world) return;
  const stops = world.stops;
  const completed = adventureProgress();

  pathEl.innerHTML = "";
  let playerPlaced = false;

  const gameLabels = {
    code_output: "🖥️ Kod",
    bug_hunt: "🐛 Szukaj buga",
    true_false: "✅ Prawda/Fałsz",
    sort_code: "🧱 Ułóż kod",
    var_tracker: "🔍 Śledź zmienną",
  };

  stops.forEach((stop, i) => {
    const done = completed.includes(stop.id);
    const unlocked = i === 0 || completed.includes(stops[i - 1].id);
    const statusClass = done ? "completed" : unlocked ? "unlocked" : "locked";

    if (i > 0) {
      const connDone = completed.includes(stops[i - 1].id);
      const connector = document.createElement("div");
      connector.className = "adventure-stop-connector" + (connDone ? " done" : "");
      pathEl.appendChild(connector);
    }

    const stopEl = document.createElement("div");
    stopEl.className = `adventure-stop ${statusClass}`;

    const showPlayer = unlocked && !done && !playerPlaced;
    if (showPlayer) playerPlaced = true;

    stopEl.innerHTML = `
      <div class="adventure-stop-node ${statusClass}">
        ${showPlayer ? '<div class="adventure-player-marker">🧑‍💻</div>' : ""}
        <span>${done ? "✓" : (stop.icon || (i + 1))}</span>
      </div>
      <div class="adventure-stop-info">
        <div class="adventure-stop-label">${esc(stop.label)}</div>
        <div class="adventure-stop-type">
          ${gameLabels[stop.game] || "🎮 Gra"}
          <span class="adventure-stop-coins">${done ? "✅" : "🪙 " + stop.coins}</span>
        </div>
      </div>
    `;

    if (unlocked && !done) {
      stopEl.querySelector(".adventure-stop-node").addEventListener("click", () => startAdventureChallenge(stop));
      stopEl.querySelector(".adventure-stop-info").addEventListener("click", () => startAdventureChallenge(stop));
    } else if (done) {
      stopEl.addEventListener("click", () => {
        if (dom.adventureMessage) {
          dom.adventureMessage.textContent = "✅ Już ukończone! (+" + stop.coins + " monet)";
          dom.adventureMessage.style.color = "#00B894";
          setTimeout(() => { dom.adventureMessage.textContent = ""; }, 2000);
        }
      });
    }

    pathEl.appendChild(stopEl);
  });
}

/* ============ START MINI-GAME ============ */
function startAdventureChallenge(stop) {
  state.adventureCurrentStop = stop;
  advGameAttempts = 0;

  // Switch view: path → game
  if (dom.adventurePathContainer) dom.adventurePathContainer.style.display = "none";
  if (dom.adventureGameArea) dom.adventureGameArea.style.display = "block";

  // Header
  dom.adventureGameIcon.textContent = stop.icon;
  dom.adventureGameTitle.textContent = stop.label;
  dom.adventureGameCoinsBadge.textContent = "🪙 " + stop.coins;

  // Clear previous
  dom.adventureGameQuestion.textContent = "";
  dom.adventureGameCode.style.display = "none";
  dom.adventureGameCode.textContent = "";
  dom.adventureGameContent.innerHTML = "";
  dom.adventureGameFeedback.textContent = "";
  dom.adventureGameFeedback.className = "adventure-game-feedback";

  switch (stop.game) {
    case "code_output": renderCodeOutputGame(stop); break;
    case "bug_hunt":    renderBugHuntGame(stop);    break;
    case "true_false":  renderTrueFalseGame(stop);  break;
    case "sort_code":   renderSortCodeGame(stop);   break;
    case "var_tracker": renderVarTrackerGame(stop);  break;
  }
}

/* ============ GAME: CODE OUTPUT ============ */
function renderCodeOutputGame(stop) {
  dom.adventureGameQuestion.textContent = stop.question;
  dom.adventureGameCode.textContent = stop.code;
  dom.adventureGameCode.style.display = "block";

  const content = dom.adventureGameContent;
  content.className = "adventure-game-content adv-options-grid";

  stop.options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.className = "adv-option-btn";
    btn.textContent = opt;
    btn.addEventListener("click", () => checkAdvAnswer(i, stop.correct, btn, stop));
    content.appendChild(btn);
  });
}

/* ============ GAME: BUG HUNT ============ */
function renderBugHuntGame(stop) {
  dom.adventureGameQuestion.textContent = "🐛 Znajdź linię z błędem! Kliknij podejrzaną linię kodu.";
  dom.adventureGameFeedback.textContent = "💡 " + (stop.hint || "");
  dom.adventureGameFeedback.className = "adventure-game-feedback adv-hint";

  const content = dom.adventureGameContent;
  content.className = "adventure-game-content adv-bug-hunt";

  stop.lines.forEach((line, i) => {
    const row = document.createElement("div");
    row.className = "adv-code-line";
    row.innerHTML = `<span class="adv-line-num">${i + 1}</span><code>${esc(line)}</code>`;
    row.addEventListener("click", () => {
      if (row.classList.contains("adv-disabled")) return;
      advGameAttempts++;
      if (i === stop.bugLine) {
        row.classList.add("adv-bug-found");
        content.querySelectorAll(".adv-code-line").forEach(r => r.classList.add("adv-disabled"));
        dom.adventureGameFeedback.textContent = "✅ " + stop.explanation;
        dom.adventureGameFeedback.className = "adventure-game-feedback adv-correct";
        setTimeout(() => onAdventureMiniGameWin(), 1500);
      } else {
        row.classList.add("adv-not-bug");
        setTimeout(() => row.classList.remove("adv-not-bug"), 600);
        dom.adventureGameFeedback.textContent = "❌ To nie ta linia... szukaj dalej!";
        dom.adventureGameFeedback.className = "adventure-game-feedback adv-wrong";
      }
    });
    content.appendChild(row);
  });
}

/* ============ GAME: TRUE / FALSE ============ */
function renderTrueFalseGame(stop) {
  advTFIndex = 0;
  advTFWrong = 0;
  dom.adventureGameQuestion.textContent = "Prawda czy Fałsz? (" + stop.statements.length + " pytań)";
  renderTFStatement(stop);
}

function renderTFStatement(stop) {
  const stmt = stop.statements[advTFIndex];
  const content = dom.adventureGameContent;
  content.innerHTML = "";
  content.className = "adventure-game-content adv-tf-game";

  // Progress dots
  const dots = document.createElement("div");
  dots.className = "adv-tf-dots";
  stop.statements.forEach((_, i) => {
    const d = document.createElement("span");
    d.className = "adv-tf-dot" + (i < advTFIndex ? " done" : i === advTFIndex ? " current" : "");
    dots.appendChild(d);
  });
  content.appendChild(dots);

  // Statement card
  const card = document.createElement("div");
  card.className = "adv-tf-statement";
  card.textContent = stmt.text;
  content.appendChild(card);

  // Buttons
  const btns = document.createElement("div");
  btns.className = "adv-tf-buttons";
  const btnT = document.createElement("button");
  btnT.className = "adv-tf-btn adv-tf-true";
  btnT.textContent = "✅ Prawda";
  btnT.addEventListener("click", () => checkTFAnswer(true, stop));
  const btnF = document.createElement("button");
  btnF.className = "adv-tf-btn adv-tf-false";
  btnF.textContent = "❌ Fałsz";
  btnF.addEventListener("click", () => checkTFAnswer(false, stop));
  btns.appendChild(btnT);
  btns.appendChild(btnF);
  content.appendChild(btns);

  dom.adventureGameFeedback.textContent = "";
  dom.adventureGameFeedback.className = "adventure-game-feedback";
}

function checkTFAnswer(answer, stop) {
  const stmt = stop.statements[advTFIndex];
  if (answer !== stmt.answer) {
    advTFWrong++;
    dom.adventureGameFeedback.textContent = "❌ Źle! Odpowiedź: " + (stmt.answer ? "Prawda" : "Fałsz");
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-wrong";
  } else {
    dom.adventureGameFeedback.textContent = "✅ Dobrze!";
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-correct";
  }
  advTFIndex++;
  if (advTFIndex >= stop.statements.length) {
    advGameAttempts = advTFWrong;
    setTimeout(() => {
      dom.adventureGameFeedback.textContent = "✅ " + stop.explanation;
      dom.adventureGameFeedback.className = "adventure-game-feedback adv-correct";
      setTimeout(() => onAdventureMiniGameWin(), 1200);
    }, 800);
  } else {
    setTimeout(() => renderTFStatement(stop), 900);
  }
}

/* ============ GAME: SORT CODE ============ */
function renderSortCodeGame(stop) {
  advSortPlaced = [];
  advSortShuffled = stop.blocks.map((text, i) => ({ text, idx: i }));
  advShuffleArray(advSortShuffled);

  dom.adventureGameQuestion.textContent = "🧱 Klikaj bloki kodu we właściwej kolejności!";
  dom.adventureGameFeedback.textContent = "";
  dom.adventureGameFeedback.className = "adventure-game-feedback";
  renderSortUI(stop);
}

function renderSortUI(stop) {
  const content = dom.adventureGameContent;
  content.innerHTML = "";
  content.className = "adventure-game-content adv-sort-game";

  // Target — placed blocks
  const target = document.createElement("div");
  target.className = "adv-sort-target";
  if (advSortPlaced.length === 0) {
    const ph = document.createElement("div");
    ph.className = "adv-sort-placeholder";
    ph.textContent = "👆 Klikaj bloki poniżej w odpowiedniej kolejności";
    target.appendChild(ph);
  }
  advSortPlaced.forEach((block, i) => {
    const el = document.createElement("div");
    el.className = "adv-sort-block adv-placed";
    el.innerHTML = `<span class="adv-sort-num">${i + 1}</span><code>${esc(block.text)}</code>`;
    el.addEventListener("click", () => {
      advSortPlaced.splice(i);
      renderSortUI(stop);
    });
    target.appendChild(el);
  });
  content.appendChild(target);

  // Pool — available blocks
  const placedIdxs = new Set(advSortPlaced.map(b => b.idx));
  const available = advSortShuffled.filter(b => !placedIdxs.has(b.idx));
  if (available.length > 0) {
    const pool = document.createElement("div");
    pool.className = "adv-sort-pool";
    available.forEach(block => {
      const el = document.createElement("div");
      el.className = "adv-sort-block adv-available";
      el.innerHTML = `<code>${esc(block.text)}</code>`;
      el.addEventListener("click", () => {
        advSortPlaced.push(block);
        renderSortUI(stop);
        if (advSortPlaced.length === stop.blocks.length) {
          setTimeout(() => checkSortOrder(stop), 300);
        }
      });
      pool.appendChild(el);
    });
    content.appendChild(pool);
  }
}

function checkSortOrder(stop) {
  advGameAttempts++;
  const correct = advSortPlaced.every((block, i) => block.idx === i);
  if (correct) {
    dom.adventureGameContent.querySelectorAll(".adv-placed").forEach(el => el.classList.add("adv-sort-correct"));
    dom.adventureGameFeedback.textContent = "✅ " + stop.explanation;
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-correct";
    setTimeout(() => onAdventureMiniGameWin(), 1500);
  } else {
    const target = dom.adventureGameContent.querySelector(".adv-sort-target");
    if (target) { target.classList.add("adv-shake"); setTimeout(() => target.classList.remove("adv-shake"), 600); }
    dom.adventureGameFeedback.textContent = "❌ Kolejność niepoprawna — spróbuj jeszcze raz!";
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-wrong";
    setTimeout(() => { advSortPlaced = []; renderSortUI(stop); dom.adventureGameFeedback.textContent = ""; }, 1200);
  }
}

/* ============ GAME: VAR TRACKER ============ */
function renderVarTrackerGame(stop) {
  dom.adventureGameQuestion.textContent = stop.question;
  dom.adventureGameCode.textContent = stop.code;
  dom.adventureGameCode.style.display = "block";
  dom.adventureGameFeedback.textContent = "💡 Wykonaj kod w głowie krok po kroku!";
  dom.adventureGameFeedback.className = "adventure-game-feedback adv-hint";

  const content = dom.adventureGameContent;
  content.innerHTML = "";
  content.className = "adventure-game-content adv-var-tracker";

  const badge = document.createElement("div");
  badge.className = "adv-var-badge";
  badge.textContent = "🔍 Śledź: " + stop.variable;
  content.appendChild(badge);

  const opts = document.createElement("div");
  opts.className = "adv-options-grid";
  stop.options.forEach((opt, i) => {
    const btn = document.createElement("button");
    btn.className = "adv-option-btn";
    btn.textContent = stop.variable + " = " + opt;
    btn.addEventListener("click", () => {
      checkAdvAnswer(i, stop.correct, btn, stop);
      if (i === stop.correct) showVarSteps(stop);
    });
    opts.appendChild(btn);
  });
  content.appendChild(opts);
}

function showVarSteps(stop) {
  const div = document.createElement("div");
  div.className = "adv-var-steps";
  stop.steps.forEach(s => {
    const row = document.createElement("div");
    row.className = "adv-var-step";
    row.innerHTML = `<code>${esc(s.line)}</code><span class="adv-var-arrow">→</span><strong>${stop.variable} = ${s.value}</strong>`;
    div.appendChild(row);
  });
  dom.adventureGameFeedback.appendChild(div);
}

/* ============ SHARED ANSWER CHECKER ============ */
function checkAdvAnswer(selected, correct, btn, stop) {
  if (btn.classList.contains("adv-disabled")) return;
  advGameAttempts++;
  if (selected === correct) {
    btn.classList.add("adv-correct-btn");
    dom.adventureGameContent.querySelectorAll(".adv-option-btn").forEach(b => b.classList.add("adv-disabled"));
    dom.adventureGameFeedback.textContent = "✅ " + stop.explanation;
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-correct";
    setTimeout(() => onAdventureMiniGameWin(), 1500);
  } else {
    btn.classList.add("adv-wrong-btn");
    btn.classList.add("adv-disabled");
    dom.adventureGameFeedback.textContent = "❌ Nie tym razem... spróbuj inną odpowiedź!";
    dom.adventureGameFeedback.className = "adventure-game-feedback adv-wrong";
  }
}

/* ============ WIN HANDLER ============ */
function onAdventureMiniGameWin() {
  const stop = state.adventureCurrentStop;
  if (!stop) return;

  const completed = adventureProgress();
  if (!completed.includes(stop.id)) completed.push(stop.id);

  const stars = advGameAttempts <= 0 ? 3 : advGameAttempts === 1 ? 2 : 1;
  saveAdventureProgress(stop.id, stars);

  if (dom.adventureCompleteStars) dom.adventureCompleteStars.textContent = starStr(stars, 3);
  if (dom.adventureCompleteMsg) {
    const msgs = { 1: "Dobra robota!", 2: "Świetna robota!", 3: "Perfekcyjnie! 🌟" };
    dom.adventureCompleteMsg.textContent = (msgs[stars] || "Brawo!") + " +" + stop.coins + " 🪙";
  }
  showModal("adventure-complete");
}

async function saveAdventureProgress(stopId, stars) {
  try {
    const res = await fetch(`${API}/api/progress/${encodeURIComponent(state.username)}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ adventure_id: stopId, adventure_stars: stars }),
    });
    state.progress = await res.json();
    updateStarDisplay();
  } catch (e) { console.error("Adventure save failed", e); }
}

/* ============ NAVIGATION ============ */
function onAdventureBack() {
  if (state.adventureCurrentStop) {
    exitAdventureGame();
    renderAdventurePath();
  } else if (state.adventureWorld) {
    stopAdventure();
    showScreen("levels");
    renderAdventureMap();
  } else {
    showScreen("levels");
  }
}

function exitAdventureGame() {
  state.adventureCurrentStop = null;
  if (dom.adventureGameArea) dom.adventureGameArea.style.display = "none";
  if (dom.adventurePathContainer) dom.adventurePathContainer.style.display = "";
}

function onAdventureNext() {
  hideModal("adventure-complete");
  exitAdventureGame();
  if (state.adventureWorld) {
    renderAdventurePath();
    if (dom.adventureCoins) dom.adventureCoins.textContent = "🪙 " + adventureCoinsTotal();
    if (dom.adventureCoinsTotal) dom.adventureCoinsTotal.textContent = adventureCoinsTotal();
  }
}

function stopAdventure() {
  state.adventureActive = false;
  state.adventureWorld = null;
  state.adventureCurrentStop = null;
}

/* Legacy stubs — quiz.js and logic.js still call these safely */
function checkAdventureReturn() { return false; }
function onAdventureTaskComplete() {}
